    <summary height="20">
        <element kind="line" uuid="d3000040-0000-0000-0000-000000000040"
                 x="0" y="0" width="535" height="1"><pen lineWidth="1.0"/></element>
        <element kind="staticText" uuid="d3000041-0000-0000-0000-000000000041"
