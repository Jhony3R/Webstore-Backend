        <element kind="line" uuid="d3000024-0000-0000-0000-000000000024"
                 x="0" y="16" width="535" height="1"><pen lineStyle="Dashed"/></element>
    </columnHeader>

    <detail>
        <band height="16" splitType="Stretch">
            <element kind="textField" uuid="d3000030-0000-0000-0000-000000000030"
                     x="0" y="1" width="120" height="14" fontName="SansSerif" fontSize="8.0" pattern="dd/MM/yyyy"
                     blankWhenNull="true" vTextAlign="Middle">
                <expression><![CDATA[$F{fecha}]]></expression>
            </element>
            <element kind="textField" uuid="d3000031-0000-0000-0000-000000000031"
                     x="120" y="1" width="135" height="14" fontName="SansSerif" fontSize="8.0" pattern="S/ #,##0.00"
