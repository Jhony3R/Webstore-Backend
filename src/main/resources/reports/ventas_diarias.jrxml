<jasperReport name="ventas_diarias" language="java"
              pageWidth="595" pageHeight="842"
              columnWidth="535" leftMargin="30" rightMargin="30"
              topMargin="20" bottomMargin="20"
              uuid="d1000001-0000-0000-0000-000000000001">

    <parameter name="titulo" class="java.lang.String"/>
    <parameter name="rango" class="java.lang.String"/>

    <field name="fecha" class="java.time.LocalDate"/>
    <field name="cantidadVentas" class="java.lang.Long"/>
    <field name="totalEfectivo" class="java.lang.Double"/>
    <field name="totalYape" class="java.lang.Double"/>
    <field name="totalPlin" class="java.lang.Double"/>
    <field name="totalTarjeta" class="java.lang.Double"/>
    <field name="totalTransferencia" class="java.lang.Double"/>
    <field name="totalGeneral" class="java.lang.Double"/>

    <background splitType="Stretch"/>

    <pageHeader height="45" splitType="Stretch">
        <element kind="textField" uuid="d1000010-0000-0000-0000-000000000010"
                 x="0" y="0" width="535" height="20"
                 fontName="SansSerif" fontSize="14.0" bold="true"
                 blankWhenNull="true" hTextAlign="Left" vTextAlign="Middle">
            <expression><![CDATA[$P{titulo}]]></expression>
        </element>
        <element kind="textField" uuid="d1000011-0000-0000-0000-000000000011"
                 x="0" y="20" width="535" height="14"
                 fontName="SansSerif" fontSize="9.0"
                 blankWhenNull="true" hTextAlign="Left" vTextAlign="Middle">
            <expression><![CDATA[$P{rango}]]></expression>
        </element>
        <element kind="line" uuid="d1000012-0000-0000-0000-000000000012"
                 x="0" y="40" width="535" height="1">
            <pen lineWidth="1.0"/>
        </element>
    </pageHeader>

    <columnHeader height="18" splitType="Stretch">
        <element kind="staticText" uuid="d1000020-0000-0000-0000-000000000020"
                 x="0" y="2" width="65" height="14" fontName="SansSerif" fontSize="8.0" bold="true">
            <text><![CDATA[Fecha]]></text>
        </element>
        <element kind="staticText" uuid="d1000021-0000-0000-0000-000000000021"
                 x="65" y="2" width="55" height="14" fontName="SansSerif" fontSize="8.0" bold="true" hTextAlign="Center">
            <text><![CDATA[N° Ventas]]></text>
        </element>
        <element kind="staticText" uuid="d1000022-0000-0000-0000-000000000022"
                 x="120" y="2" width="80" height="14" fontName="SansSerif" fontSize="8.0" bold="true" hTextAlign="Right">
            <text><![CDATA[Efectivo]]></text>
        </element>
        <element kind="staticText" uuid="d1000023-0000-0000-0000-000000000023"
                 x="200" y="2" width="65" height="14" fontName="SansSerif" fontSize="8.0" bold="true" hTextAlign="Right">
            <text><![CDATA[Yape]]></text>
        </element>
        <element kind="staticText" uuid="d1000024-0000-0000-0000-000000000024"
                 x="265" y="2" width="65" height="14" fontName="SansSerif" fontSize="8.0" bold="true" hTextAlign="Right">
            <text><![CDATA[Plin]]></text>
        </element>
        <element kind="staticText" uuid="d1000025-0000-0000-0000-000000000025"
                 x="330" y="2" width="75" height="14" fontName="SansSerif" fontSize="8.0" bold="true" hTextAlign="Right">
            <text><![CDATA[Tarjeta]]></text>
        </element>
        <element kind="staticText" uuid="d1000026-0000-0000-0000-000000000026"
                 x="405" y="2" width="65" height="14" fontName="SansSerif" fontSize="8.0" bold="true" hTextAlign="Right">
            <text><![CDATA[Transf.]]></text>
        </element>
        <element kind="staticText" uuid="d1000027-0000-0000-0000-000000000027"
                 x="470" y="2" width="65" height="14" fontName="SansSerif" fontSize="8.0" bold="true" hTextAlign="Right">
            <text><![CDATA[Total]]></text>
        </element>
        <element kind="line" uuid="d1000028-0000-0000-0000-000000000028"
                 x="0" y="16" width="535" height="1">
            <pen lineStyle="Dashed"/>
        </element>
    </columnHeader>

    <detail>
        <band height="16" splitType="Stretch">
            <element kind="textField" uuid="d1000030-0000-0000-0000-000000000030"
                     x="0" y="1" width="65" height="14" fontName="SansSerif" fontSize="8.0"
                     blankWhenNull="true" pattern="dd/MM/yyyy" vTextAlign="Middle">
                <expression><![CDATA[$F{fecha}]]></expression>
            </element>
            <element kind="textField" uuid="d1000031-0000-0000-0000-000000000031"
                     x="65" y="1" width="55" height="14" fontName="SansSerif" fontSize="8.0"
                     blankWhenNull="true" hTextAlign="Center" vTextAlign="Middle">
                <expression><![CDATA[$F{cantidadVentas}]]></expression>
            </element>
            <element kind="textField" uuid="d1000032-0000-0000-0000-000000000032"
                     x="120" y="1" width="80" height="14" fontName="SansSerif" fontSize="8.0" pattern="S/ #,##0.00"
                     blankWhenNull="true" hTextAlign="Right" vTextAlign="Middle">
                <expression><![CDATA[$F{totalEfectivo}]]></expression>
            </element>
            <element kind="textField" uuid="d1000033-0000-0000-0000-000000000033"
                     x="200" y="1" width="65" height="14" fontName="SansSerif" fontSize="8.0" pattern="S/ #,##0.00"
                     blankWhenNull="true" hTextAlign="Right" vTextAlign="Middle">
                <expression><![CDATA[$F{totalYape}]]></expression>
            </element>
            <element kind="textField" uuid="d1000034-0000-0000-0000-000000000034"
                     x="265" y="1" width="65" height="14" fontName="SansSerif" fontSize="8.0" pattern="S/ #,##0.00"
                     blankWhenNull="true" hTextAlign="Right" vTextAlign="Middle">
                <expression><![CDATA[$F{totalPlin}]]></expression>
            </element>
            <element kind="textField" uuid="d1000035-0000-0000-0000-000000000035"
                     x="330" y="1" width="75" height="14" fontName="SansSerif" fontSize="8.0" pattern="S/ #,##0.00"
                     blankWhenNull="true" hTextAlign="Right" vTextAlign="Middle">
                <expression><![CDATA[$F{totalTarjeta}]]></expression>
            </element>
            <element kind="textField" uuid="d1000036-0000-0000-0000-000000000036"
                     x="405" y="1" width="65" height="14" fontName="SansSerif" fontSize="8.0" pattern="S/ #,##0.00"
                     blankWhenNull="true" hTextAlign="Right" vTextAlign="Middle">
                <expression><![CDATA[$F{totalTransferencia}]]></expression>
            </element>
            <element kind="textField" uuid="d1000037-0000-0000-0000-000000000037"
                     x="470" y="1" width="65" height="14" fontName="SansSerif" fontSize="8.0" bold="true" pattern="S/ #,##0.00"
                     blankWhenNull="true" hTextAlign="Right" vTextAlign="Middle">
                <expression><![CDATA[$F{totalGeneral}]]></expression>
            </element>
        </band>
    </detail>

    <summary height="15">
        <element kind="line" uuid="d1000040-0000-0000-0000-000000000040"
                 x="0" y="0" width="535" height="1">
            <pen lineWidth="1.0"/>
        </element>
        <element kind="textField" uuid="d1000041-0000-0000-0000-000000000041"
                 x="0" y="3" width="535" height="10" fontName="SansSerif" fontSize="7.0" italic="true"
                 hTextAlign="Right" evaluationTime="Report">
            <expression><![CDATA["Total registros: " + $V{REPORT_COUNT}]]></expression>
        </element>
    </summary>

</jasperReport>