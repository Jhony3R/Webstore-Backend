            <expression><![CDATA[$P{titulo}]]></expression>
        </element>
        <element kind="textField" uuid="d3000011-0000-0000-0000-000000000011"
                 x="0" y="20" width="535" height="14" fontName="SansSerif" fontSize="9.0"
                 blankWhenNull="true" hTextAlign="Left" vTextAlign="Middle">
            <expression><![CDATA[$P{rango}]]></expression>
        </element>
        <element kind="line" uuid="d3000012-0000-0000-0000-000000000012"
