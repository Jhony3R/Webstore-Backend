<jasperReport name="estado_inventario" language="java"
              pageWidth="595" pageHeight="842"
              columnWidth="535" leftMargin="30" rightMargin="30"
              topMargin="20" bottomMargin="20"
              uuid="d4000001-0000-0000-0000-000000000001">

    <parameter name="titulo" class="java.lang.String"/>
    <parameter name="rango" class="java.lang.String"/>

    <field name="codigo" class="java.lang.String"/>
    <field name="descripcion" class="java.lang.String"/>
    <field name="categoria" class="java.lang.String"/>
    <field name="precioVenta" class="java.lang.Double"/>
    <field name="stockActual" class="java.lang.Integer"/>
    <field name="stockMinimo" class="java.lang.Integer"/>

    <background splitType="Stretch"/>

    <pageHeader height="45" splitType="Stretch">
        <element kind="textField" uuid="d4000010-0000-0000-0000-000000000010"
                 x="0" y="0" width="535" height="20" fontName="SansSerif" fontSize="14.0" bold="true"
                 blankWhenNull="true" hTextAlign="Left" vTextAlign="Middle">
            <expression><![CDATA[$P{titulo}]]></expression>
        </element>
        <element kind="textField" uuid="d4000011-0000-0000-0000-000000000011"
                 x="0" y="20" width="535" height="14" fontName="SansSerif" fontSize="9.0"
                 blankWhenNull="true" hTextAlign="Left" vTextAlign="Middle">
            <expression><![CDATA[$P{rango}]]></expression>
        </element>
        <element kind="line" uuid="d4000012-0000-0000-0000-000000000012"
                 x="0" y="40" width="535" height="1"><pen lineWidth="1.0"/></element>
    </pageHeader>

    <columnHeader height="18" splitType="Stretch">
        <element kind="staticText" uuid="d4000020-0000-0000-0000-000000000020"
                 x="0" y="2" width="55" height="14" fontName="SansSerif" fontSize="8.0" bold="true">
            <text><![CDATA[Código]]></text>
        </element>
        <element kind="staticText" uuid="d4000021-0000-0000-0000-000000000021"
                 x="55" y="2" width="190" height="14" fontName="SansSerif" fontSize="8.0" bold="true">
            <text><![CDATA[Producto]]></text>
        </element>
        <element kind="staticText" uuid="d4000022-0000-0000-0000-000000000022"
                 x="245" y="2" width="100" height="14" fontName="SansSerif" fontSize="8.0" bold="true">
            <text><![CDATA[Categoría]]></text>
        </element>
        <element kind="staticText" uuid="d4000023-0000-0000-0000-000000000023"
                 x="345" y="2" width="70" height="14" fontName="SansSerif" fontSize="8.0" bold="true" hTextAlign="Right">
            <text><![CDATA[P. Venta]]></text>
        </element>
        <element kind="staticText" uuid="d4000024-0000-0000-0000-000000000024"
                 x="415" y="2" width="55" height="14" fontName="SansSerif" fontSize="8.0" bold="true" hTextAlign="Center">
            <text><![CDATA[Stock]]></text>
        </element>
        <element kind="staticText" uuid="d4000025-0000-0000-0000-000000000025"
                 x="470" y="2" width="65" height="14" fontName="SansSerif" fontSize="8.0" bold="true" hTextAlign="Center">
            <text><![CDATA[Mínimo]]></text>
        </element>
        <element kind="line" uuid="d4000026-0000-0000-0000-000000000026"
                 x="0" y="16" width="535" height="1"><pen lineStyle="Dashed"/></element>
    </columnHeader>

    <detail>
        <band height="16" splitType="Stretch">
            <element kind="textField" uuid="d4000030-0000-0000-0000-000000000030"
                     x="0" y="1" width="55" height="14" fontName="SansSerif" fontSize="8.0"
                     blankWhenNull="true" vTextAlign="Middle">
                <expression><![CDATA[$F{codigo}]]></expression>
            </element>
            <element kind="textField" uuid="d4000031-0000-0000-0000-000000000031"
                     x="55" y="1" width="190" height="14" fontName="SansSerif" fontSize="8.0"
                     blankWhenNull="true" vTextAlign="Middle">
                <expression><![CDATA[$F{descripcion}]]></expression>
            </element>
            <element kind="textField" uuid="d4000032-0000-0000-0000-000000000032"
                     x="245" y="1" width="100" height="14" fontName="SansSerif" fontSize="8.0"
                     blankWhenNull="true" vTextAlign="Middle">
                <expression><![CDATA[$F{categoria}]]></expression>
            </element>
            <element kind="textField" uuid="d4000033-0000-0000-0000-000000000033"
                     x="345" y="1" width="70" height="14" fontName="SansSerif" fontSize="8.0" pattern="S/ #,##0.00"
                     blankWhenNull="true" hTextAlign="Right" vTextAlign="Middle">
                <expression><![CDATA[$F{precioVenta}]]></expression>
            </element>
            <element kind="textField" uuid="d4000034-0000-0000-0000-000000000034"
                     x="415" y="1" width="55" height="14" fontName="SansSerif" fontSize="8.0"
                     blankWhenNull="true" hTextAlign="Center" vTextAlign="Middle">
                <expression><![CDATA[$F{stockActual}]]></expression>
            </element>
            <element kind="textField" uuid="d4000035-0000-0000-0000-000000000035"
                     x="470" y="1" width="65" height="14" fontName="SansSerif" fontSize="8.0"
                     blankWhenNull="true" hTextAlign="Center" vTextAlign="Middle">
                <expression><![CDATA[$F{stockMinimo}]]></expression>
            </element>
        </band>
    </detail>
</jasperReport>