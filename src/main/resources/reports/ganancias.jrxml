<jasperReport name="ganancias" language="java"
              pageWidth="595" pageHeight="842"
              columnWidth="535" leftMargin="30" rightMargin="30"
              topMargin="20" bottomMargin="20"
              uuid="d3000001-0000-0000-0000-000000000001">

    <parameter name="titulo" class="java.lang.String"/>
    <parameter name="rango" class="java.lang.String"/>

    <field name="fecha" class="java.time.LocalDate"/>
    <field name="totalVentas" class="java.lang.Double"/>
    <field name="totalCompras" class="java.lang.Double"/>
    <field name="gananciaNeta" class="java.lang.Double"/>

    <variable name="sumVentas" class="java.lang.Double" calculation="Sum"><expression><![CDATA[$F{totalVentas}]]></expression></variable>
    <variable name="sumCompras" class="java.lang.Double" calculation="Sum"><expression><![CDATA[$F{totalCompras}]]></expression></variable>
    <variable name="sumGanancia" class="java.lang.Double" calculation="Sum"><expression><![CDATA[$F{gananciaNeta}]]></expression></variable>

    <background splitType="Stretch"/>

    <pageHeader height="45" splitType="Stretch">
        <element kind="textField" uuid="d3000010-0000-0000-0000-000000000010"
